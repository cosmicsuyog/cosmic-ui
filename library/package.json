{
  "name": "cosmic-ui-library",
  "version": "1.0.14",
  "description": "A lightweight React UI component library with cards, forms, navigation, dashboards, AI UI blocks, and utility components.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs/assets"
  ],
  "scripts": {
    "build": "tsup"
  },
  "author": "Suyog",
  "license": "ISC",
  "keywords": [
    "react",
    "ui",
    "components",
    "cosmic-ui",
    "component-library"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
